# ─────────────────────────────────────────────
#  JARVIS AI Backend — Environment Variables
# ─────────────────────────────────────────────

# Groq API Key (get yours at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Model to use (llama3-70b-8192 recommended for best quality)
GROQ_MODEL=llama-3.3-70b-versatile

# SQLite database file path
DATABASE_URL=sqlite+aiosqlite:///./jarvis_memory.db

# Max conversation history turns to send to model (keeps context focused)
MAX_HISTORY_TURNS=20

# Max search results to fetch per query
MAX_SEARCH_RESULTS=5

# App settings
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
